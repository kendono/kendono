{
  "dualConfigs": false,
  "showConsoleLog": false,
  "desktop": {
    "shortDelaySeconds": 1,
    "longDelaySeconds": 2,
    "delayBetweenPlugins": 40,
    "defaultStartupType": "short",
    "showDescriptions": true,
    "plugins": {
      "obsidian-editor-shortcuts": {
        "startupType": "short"
      },
      "custom-sort": {
        "startupType": "long"
      },
      "custom-font-loader": {
        "startupType": "instant"
      },
      "obsidian-hider": {
        "startupType": "short"
      },
      "open-vscode": {
        "startupType": "instant"
      },
      "plugin-reloader": {
        "startupType": "long"
      },
      "show-hidden-files": {
        "startupType": "instant"
      },
      "terminal": {
        "startupType": "short"
      },
      "vscode-editor": {
        "startupType": "short"
      },
      "obsidian-alias-from-heading": {
        "startupType": "short"
      },
      "css-editor": {
        "startupType": "short"
      },
      "folder-notes": {
        "startupType": "long"
      },
      "homepage": {
        "startupType": "short"
      },
      "codeblock-customizer": {
        "startupType": "short"
      },
      "unitade": {
        "startupType": "disabled"
      },
      "hide-folders": {
        "startupType": "short"
      },
      "obsidian-export-image": {
        "startupType": "short"
      },
      "obsidian-enhancing-export": {
        "startupType": "instant"
      },
      "webpage-html-export": {
        "startupType": "instant"
      },
      "obsidian-link-converter": {
        "startupType": "short"
      },
      "obsidian-custom-file-extensions-plugin": {
        "startupType": "short"
      },
      "better-markdown-links": {
        "startupType": "short"
      },
      "emoji-autocomplete": {
        "startupType": "short"
      },
      "emoji-shortcodes": {
        "startupType": "short"
      },
      "latex-to-unicode": {
        "startupType": "short"
      },
      "unicode-search": {
        "startupType": "short"
      }
    }
  }
}